{
	"name": "n8n-nodes-memberpass",
	"version": "1.3.3",
	"description": "n8n community node for MemberPass — monetise Telegram communities via subscriptions, access codes, and webhook events.",
	"keywords": [
		"n8n-community-node",
		"n8n-community-node-package",
		"memberpass",
		"telegram",
		"subscription",
		"membership"
	],
	"license": "MIT",
	"homepage": "https://docs.memberpass.net/integrations/n8n",
	"author": {
		"name": "Envigo Innovations",
		"email": "support@memberpass.net",
		"url": "https://www.memberpass.net"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/envigoinnovations/memberpass-n8n.git"
	},
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "npm run build",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/MemberPassApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MemberPass/MemberPass.node.js",
			"dist/nodes/MemberPassTrigger/MemberPassTrigger.node.js"
		]
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.0.0",
		"@n8n/node-cli": ">=0.23.0",
		"@types/node": "^22.9.0",
		"@typescript-eslint/parser": "^8.18.0",
		"eslint": "^9.0.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"gulp": "^5.0.0",
		"n8n-workflow": "^1.75.0",
		"prettier": "^3.4.2",
		"typescript": "^5.7.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
